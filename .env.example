# Copy to .env (next to docker-compose.yml) and fill in real values before
# `docker compose up`. Not committed with real values — see .gitignore.

# Public HTTPS URLs the Angular app's browser-side JS will call. These run in the
# end user's browser, so they must be real routable hostnames, not Docker service
# names (e.g. http://cpt-api:3002 means nothing to a browser).
CPT_API_URL=https://healthcare-api.stevenluu.com/cpt
ICD_API_URL=https://healthcare-api.stevenluu.com/icd
AI_API_URL=https://healthcare-api.stevenluu.com/ai
PATIENTS_API_URL=https://healthcare-api.stevenluu.com/patients

# Comma-separated list of origins the 4 Express APIs will accept CORS requests
# from — set this to wherever angular-dashboard is actually served publicly.
ALLOWED_ORIGINS=https://angular.stevenluu.com

# Portfolio's "Live Sandboxes" links (browser-side, baked in at build time).
# Defaults to http://localhost:8082 / :8081 when unset — correct for local
# `docker compose up`, since that's where angular-dashboard/react-dashboard are
# published. Set these explicitly only for a real public deployment.
NEXT_PUBLIC_ANGULAR_SANDBOX_URL=https://angular.stevenluu.com
NEXT_PUBLIC_REACT_SANDBOX_URL=https://react.stevenluu.com

# For local testing before deploying to the NAS, point all of the above at
# localhost instead, e.g.:
#   CPT_API_URL=http://localhost:3002
#   ICD_API_URL=http://localhost:3003
#   AI_API_URL=http://localhost:3001
#   PATIENTS_API_URL=http://localhost:3004
#   ALLOWED_ORIGINS=http://localhost:8082

# Cloudflare Tunnel connector token (NAS only — see deploy/synology/cloudflare-tunnel.md).
# Publishes the stack through Cloudflare's edge so the home IP stays hidden and no
# inbound router ports are open. Get it from Zero Trust → Networks → Tunnels →
# your tunnel → Install connector (Docker) → copy the eyJ... token. Not needed for
# local `docker compose up`.
CLOUDFLARE_TUNNEL_TOKEN=
