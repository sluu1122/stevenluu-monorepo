# Copy to .env (next to docker-compose.yml) and fill in real values before
# `docker compose up`. Not committed with real values — see .gitignore.

# Public HTTPS URLs the Angular app's browser-side JS will call. These run in the
# end user's browser, so they must be real routable hostnames, not Docker service
# names (e.g. http://cpt-api:3002 means nothing to a browser).
CPT_API_URL=https://healthcare-api.yourdomain.com/cpt
ICD_API_URL=https://healthcare-api.yourdomain.com/icd
AI_API_URL=https://healthcare-api.yourdomain.com/ai
PATIENTS_API_URL=https://healthcare-api.yourdomain.com/patients

# Comma-separated list of origins the 4 Express APIs will accept CORS requests
# from — set this to wherever angular-dashboard is actually served publicly.
ALLOWED_ORIGINS=https://angular.yourdomain.com

# For local testing before deploying to the NAS, point all of the above at
# localhost instead, e.g.:
#   CPT_API_URL=http://localhost:3002
#   ICD_API_URL=http://localhost:3003
#   AI_API_URL=http://localhost:3001
#   PATIENTS_API_URL=http://localhost:3004
#   ALLOWED_ORIGINS=http://localhost:8082
