{
  "name": "stevenluu-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.16",
    "typescript": "~6.0.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.6.4",
  "workspaces": [
    "apps/*",
    "apps/*/*",
    "packages/*"
  ]
}
